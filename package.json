{
  "name": "oscd-network-config",
  "description": "This plugin uses the information provide by the Network Data to create an initial configuration for Cisco IE-9320 devices.",
  "license": "Apache-2.0",
  "author": "Daniel Mulholland",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/oscd-network-config.js",
  "module": "dist/oscd-network-config.js",
  "exports": {
    ".": "./dist/oscd-network-config.js"
  },
  "scripts": {
    "start": "npm run build && concurrently -k -r \"tsc -b --watch --preserveWatchOutput\" \"wds\"",
    "start:build": "npm run build && es-dev-server --root-dir dist --app-index index.html --compatibility none --open",
    "start:bundle": "npm run bundle && es-dev-server --root-dir dist --app-index index.html --compatibility none --open",
    "test": "wtr --coverage",
    "test:watch": "npm run build && concurrently -k -r \"tsc -b --watch --preserveWatchOutput\" \"wtr --watch --coverage\"",
    "analyze": "cem analyze --litelement",
    "deploy": "npm run bundle && gh-pages --dist 'dist'",
    "build": "npm run compile",
    "compile": "tsc -b",
    "bundle": "rimraf dist && rollup -c rollup.config.js",
    "doc": "npm run analyze -- --exclude dist && typedoc --out dist/doc oscd-network-config.ts",
    "prepublish": "npm run lint && npm run build && npm run doc",
    "lint": "eslint --ext .ts,.html . --ignore-path .gitignore && prettier \"**/*.ts\" --check --ignore-path .gitignore",
    "format": "eslint --ext .ts,.html . --fix --ignore-path .gitignore && prettier \"**/*.ts\" --write --ignore-path .gitignore",
    "prepare": "husky install"
  },
  "dependencies": {
    "@material/mwc-snackbar": "^0.27.0",
    "@material/web": "^2.4.1",
    "@omicronenergy/oscd-shell": "^0.0.13",
    "@openscd/open-scd-core": "^0.0.2",
    "@openscd/oscd-api": "^0.1.6",
    "@openscd/scl-lib": "^2.0.0",
    "@viz-js/viz": "^3.25.0",
    "@webcomponents/scoped-custom-element-registry": "^0.0.10",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@omicronenergy/oscd-editor": "^1.7.1",
    "@open-wc/eslint-config": "^12.0.1",
    "@open-wc/testing": "^4.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/mocha": "^10.0.10",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.9.0",
    "@web/dev-server": "^0.4.6",
    "@web/rollup-plugin-import-meta-assets": "^2.3.3",
    "@web/test-runner": "^0.20.2",
    "concurrently": "^9.2.1",
    "es-dev-server": "^1.23.1",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-tsdoc": "^0.5.2",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rollup-plugin-copy": "^3.5.0",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3"
  },
  "customElements": "custom-elements.json",
  "eslintConfig": {
    "parser": "@typescript-eslint/parser",
    "extends": [
      "@open-wc",
      "prettier"
    ],
    "plugins": [
      "@typescript-eslint"
    ],
    "rules": {
      "@typescript-eslint/no-unused-vars": [
        2
      ],
      "import/no-unresolved": "off",
      "import/extensions": [
        "error",
        "always",
        {
          "ignorePackages": true
        }
      ],
      "import/no-extraneous-dependencies": [
        "error",
        {
          "devDependencies": [
            "**/*.spec.ts"
          ]
        }
      ],
      "lit/no-classfield-shadowing": "off",
      "no-duplicate-imports": "off",
      "no-unused-vars": "off",
      "no-redeclare": "off"
    }
  },
  "prettier": {
    "singleQuote": true,
    "arrowParens": "avoid",
    "trailingComma": "none"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
